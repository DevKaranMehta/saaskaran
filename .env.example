# ── App ─────────────────────────────────────────────────────────
APP_NAME="SaaS Factory"
DOMAIN=factory.supportbox.cloud
SECRET_KEY=change-me-to-64-char-random-hex-string
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=saas
POSTGRES_PASSWORD=saaspassword
POSTGRES_DB=saasfactory
DATABASE_URL=postgresql+asyncpg://saas:saaspassword@localhost:5433/saasfactory

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_USER=saas
RABBITMQ_PASS=saaspassword
RABBITMQ_URL=amqp://saas:saaspassword@localhost:5673/

# ── Anthropic (Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Cloudflare R2 ────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_BUCKET_NAME=saas-factory-uploads
R2_PUBLIC_URL=

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8001
NEXT_PUBLIC_APP_NAME="SaaS Factory"
NEXT_PUBLIC_DOMAIN=factory.supportbox.cloud
